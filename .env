DATABASE_URL=file:/home/z/my-project/db/custom.db

# 公共 AI 默认配置。私有 API Key、模型和 Base URL 请放在 .env.local。
AI_API_PROTOCOL=openai-completions

# 流式 AI 翻译超时配置，单位毫秒。
# 连接超时：AI 接口在该时间内没有建立响应就中止。旧变量 AI_STREAM_TIMEOUT_MS 仍作为兼容回退。
AI_STREAM_CONNECT_TIMEOUT_MS=

# 总超时：从开始请求到结束的最大允许时间；即使中间持续收到 SSE 事件，超过也会中止。
AI_STREAM_TOTAL_TIMEOUT_MS=

# 空闲超时：连接建立后，超过该时间没有收到任何响应 chunk 就中止。
AI_STREAM_INACTIVITY_TIMEOUT_MS=

# AI 翻译配置
# 内置 AI (z-ai-web-dev-sdk) 仅在云端沙箱环境可用，本地部署请配置以下变量
# 配置后，"内置 AI" 模式将使用此环境变量作为默认 AI 提供商

# AI 提供商类型: env / builtin（默认 builtin，设置 env 后使用下方配置）
AI_PROVIDER=env

# API 协议: openai-completions / openai-responses / anthropic-messages
# AI_API_PROTOCOL=openai-completions

# API Base URL（不要带尾部斜杠）
# OpenAI:        https://api.openai.com/v1
# DeepSeek:      https://api.deepseek.com/v1
# Kimi/Moonshot: https://api.moonshot.cn/v1
# 智谱/GLM:      https://open.bigmodel.cn/api/paas/v4
# 千问/Qwen:     https://dashscope.aliyuncs.com/compatible-mode/v1
# Claude:        https://api.anthropic.com（需配合 anthropic-messages 协议）
AI_BASE_URL=

# API Key
AI_API_KEY=

# 模型名称
# OpenAI:    gpt-4o / gpt-4o-mini
# DeepSeek:  deepseek-chat / deepseek-coder
# Kimi:      moonshot-v1-8k / moonshot-v1-32k
# 智谱:      glm-4 / glm-4-flash
# 千问:      qwen-turbo / qwen-plus / qwen-max
# Claude:    claude-3-5-sonnet-20241022 / claude-3-haiku-20240307
AI_MODEL=
